# Devin Security Remediation Orchestrator - example environment
# Copy to `.env` and adjust. All values are optional in simulation mode.

# --- Mode ---
# When true (or when Devin creds are missing) the service uses a built-in
# simulated Devin client so you can run end-to-end with no credentials.
SIMULATION_MODE=true

# --- Devin API (required for LIVE mode) ---
DEVIN_API_KEY=
DEVIN_ORG_ID=
DEVIN_API_BASE=https://api.devin.ai/v3

# --- GitHub webhook ---
# Shared secret configured on the GitHub webhook. If empty, signature
# verification is skipped (development only).
GITHUB_WEBHOOK_SECRET=

# --- Storage ---
DATABASE_PATH=data/orchestrator.db

# --- Behaviour ---
POLL_INTERVAL_SECONDS=15
TRIGGER_LABELS=devin-remediate,security,dependency,code-quality

# --- Simulation tuning (ignored in LIVE mode) ---
SIM_SESSION_DURATION_SECONDS=20
SIM_FAILURE_RATE=0.2

# --- Server ---
HOST=0.0.0.0
PORT=8000
