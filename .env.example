# Devin Security Remediation Orchestrator - example environment
# Copy to `.env` and adjust. All values are optional in simulation mode.

# --- Mode ---
# When true (or when Devin creds are missing) the service uses a built-in
# simulated Devin client so you can run end-to-end with no credentials.
SIMULATION_MODE=true

# --- Devin API (required for LIVE mode) ---
DEVIN_API_KEY=
DEVIN_ORG_ID=
DEVIN_API_BASE=https://api.devin.ai/v3

# --- GitHub (standalone monitor) ---
# Repository the monitor polls for eligible issues.
GITHUB_REPO=royendo/superset-devin
# Personal access token used to read issues (optional for public repos, but
# recommended to avoid the 60 req/hr unauthenticated rate limit). A
# fine-grained PAT scoped to this repo with "Issues: Read-only" is enough.
GITHUB_TOKEN=
GITHUB_API_BASE=https://api.github.com

# --- Storage ---
DATABASE_PATH=data/orchestrator.db

# --- Behaviour ---
# Session reconciliation interval (refreshing running Devin sessions).
POLL_INTERVAL_SECONDS=15
# Standalone monitor: scan the repo for new issues on this interval.
ISSUE_POLLING_ENABLED=true
ISSUE_POLL_INTERVAL_SECONDS=30
TRIGGER_LABELS=devin-remediate,security,dependency,code-quality

# --- Simulation tuning (ignored in LIVE mode) ---
SIM_SESSION_DURATION_SECONDS=20
SIM_FAILURE_RATE=0.2

# --- Server ---
HOST=0.0.0.0
PORT=8000
# Optional shared secret protecting the manual-trigger endpoints. When set,
# POST /poll/run and /simulate/issue require header `X-Auth-Token: <value>`.
# Leave empty to keep them open for the zero-cred local demo.
POLL_API_TOKEN=
